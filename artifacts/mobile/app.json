{
  "expo": {
    "owner": "coverly",
    "name": "Coverly",
    "slug": "coverly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/coverly-app-icon-1024.png",
    "scheme": "coverly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand/coverly-splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6FBFA"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/brand/coverly-app-icon-1024.png",
      "bundleIdentifier": "nz.coverly.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "nz.coverly.app",
      "versionCode": 1,
      "icon": "./assets/brand/coverly-android-icon-safe.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/coverly-android-adaptive-foreground-safe.png",
        "backgroundColor": "#F6FBFA"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/brand/coverly-app-icon-1024.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Coverly to take property, room, item and evidence photos.",
          "photosPermission": "Allow Coverly to choose property, room, item and evidence photos.",
          "microphonePermission": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Coverly to use your microphone to add item details by voice."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e5e80314-7ccd-4981-97c4-5be844c2967a"
      }
    }
  }
}
